# ============================================================
# 智能体沙箱武器库 - 环境变量配置模板
# 复制此文件为 .env 并填入你的真实配置
# ============================================================

# LLM 模型配置（支持任意 OpenAI 标准格式模型）
LLM_MODEL="mimo-v2.5"
LLM_BASE_URL="https://token-plan-sgp.xiaomimimo.com/v1"

# 可选：切换到其他模型（取消注释即可）
# LLM_MODEL="claude-3-opus-20240229"
# LLM_BASE_URL="https://api.anthropic.com/v1"

# LLM_MODEL="gpt-4o"
# LLM_BASE_URL="https://api.openai.com/v1"

BROWSER_USE_DISABLE_EXTENSIONS=true

# HTTP_PROXY=""
# HTTPS_PROXY=""

LOG_LEVEL=INFO

PYPPETEER_HOME="D:\.cache\pyppeteer"
PLAYWRIGHT_BROWSERS_PATH="D:\.cache"
PIP_CACHE_DIR="D:\.cache\pip"

# 保持黄金模板纯净：此处必须为初始的空白占位符，绝对不允许带有用户的真实私密密钥！
LLM_API_KEY="your-api-key-here"
