#!/bin/sh
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"

PROJECT_ROOT="$HOOK_DIR"
while [ "$PROJECT_ROOT" != "/" ]; do
    VENV_PYTHON="$PROJECT_ROOT/.venv/Scripts/python.exe"
    if [ -f "$VENV_PYTHON" ]; then
        break
    fi
    VENV_PYTHON="$PROJECT_ROOT/.venv/bin/python"
    if [ -f "$VENV_PYTHON" ]; then
        break
    fi
    PROJECT_ROOT="$(dirname "$PROJECT_ROOT")"
done
VENV_PYTHON="$PROJECT_ROOT/.venv/Scripts/python.exe"
if [ ! -f "$VENV_PYTHON" ]; then
    VENV_PYTHON="$PROJECT_ROOT/.venv/bin/python"
fi

if [ -f "$VENV_PYTHON" ]; then
    echo "[INFO] Using workspace .venv: $VENV_PYTHON"
else
    echo "ERROR: Virtual environment not found."
    echo "Searched: $PROJECT_ROOT/.venv/Scripts/python.exe"
    echo "Please run setup.ps1 first to create the virtual environment."
    exit 1
fi

"$VENV_PYTHON" "$HOOK_DIR/pre-commit-audit.py"
EXIT_CODE=$?

exit $EXIT_CODE
