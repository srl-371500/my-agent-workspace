#!/bin/sh
# Pre-commit hook - shell wrapper
# Dynamically detects Python from local .venv or system PATH
# No C drive dependency - fully sandboxed in project directory

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/.." && pwd)"

VENV_PYTHON="$PROJECT_ROOT/services/browser_distillation/.venv/Scripts/python.exe"

if [ -f "$VENV_PYTHON" ]; then
    PY_EXE="$VENV_PYTHON"
elif command -v python > /dev/null 2>&1; then
    PY_EXE="python"
elif command -v python3 > /dev/null 2>&1; then
    PY_EXE="python3"
else
    echo "ERROR: Python not found. Please ensure .venv exists or Python is in PATH."
    exit 1
fi

"$PY_EXE" "$HOOK_DIR/pre-commit-audit.py"
EXIT_CODE=$?

exit $EXIT_CODE